        -stylus
            @import "stylus/base"

            #app-icon
                filter: drop-shadow(0 0px 1px rgba(77, 62, 86, 0.4)) drop-shadow(0 9px 17px rgba(77, 62, 86, 0.4))

            h1, h2
                color var(--color-mauve-lightgray)
            h3
                color var(--color-mauve-gray)
            a
                color var(--color-mauve-gray)
            em
                color var(--color-rose-600)
            strong
                color var(--color-rose-900)
            code
                font-size smaller
            code, .code
                font-family monoSpace
                font-weight 600
                color var(--color-rose-900) !important
                background-color alpha(black, 0.1) !important

            pre
                margin 1rem 0
                code
                    color var(--color-rose-200) !important
                    font-size 0.8rem
            .codehilite
                width 100%
                background-color var(--color-mauve-black) !important
                font-size 0.8rem
                code
                    background transparent !important
                    color white

            table
                width 100%
                margin 1rem 0
                border-collapse collapse
                font-size 0.9rem
            th, td
                border 1px solid var(--color-rose-100)
                padding 0.5rem 0.75rem
                text-align left
                vertical-align top
            th
                background var(--color-rose-50)
                color var(--color-mauve-gray)
                font-weight 600

            .links
                a
                    background-color alpha(black, 0.1)
                    color black
            div
                code
                    background-color alpha(black, 0.75)
                    color var(--color-rose-200)
                    padding 0.15em 0.3em
                    border-radius 8px
                    font-size 0.8em

            .sandbox-warning
                code, div code
                    background-color alpha(black, 0.06) !important
                    color var(--color-amber-900) !important
                    border 1px solid alpha(black, 0.1)
                    padding 0.1em 0.35em
                    border-radius 5px
                    font-size 0.85em
                    font-weight 600

            .free-note
                code, div code
                    background-color alpha(black, 0.06) !important
                    color var(--color-sky-900) !important
                    border 1px solid alpha(black, 0.1)
                    padding 0.1em 0.35em
                    border-radius 5px
                    font-size 0.85em
                    font-weight 600

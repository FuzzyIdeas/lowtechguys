                    a.btn.mt-6.text-white.bg-gray-700.!min-h-[50px].!h-[50px].hover:text-white.hover:bg-gray-600.!rounded-xl.!py-2.shadow-xl href="https://files.lowtechguys.com/releases/Cling.dmg"
                        .flex.flex-col.items-start
